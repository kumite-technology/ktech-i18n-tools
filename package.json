{
    "name": "@ktech/i18n-tools",
    "version": "1.0.3",
    "private": true,
    "description": "Reusable i18n translation CLI for KTech repositories",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
        "ktech-i18n-translate": "dist/cli.js",
        "ktech-i18n-translate-docs": "dist/cli-docs.js"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "prepare": "",
        "prepack": "",
        "build": "tsc -p tsconfig.json",
        "clean": "rm -rf dist",
        "dev": "tsx src/cli.ts",
        "translate": "tsx src/cli.ts"
    },
    "engines": {
        "node": ">=20"
    },
    "dependencies": {
        "fast-glob": "^3.3.3",
        "openai": "^5.7.0"
    },
    "devDependencies": {
        "@types/node": "^24.0.3",
        "prettier": "^3.8.1",
        "tsx": "^4.20.3",
        "typescript": "^5.8.3"
    },
    "packageManager": "yarn@4.13.0"
}
